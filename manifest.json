{
  "manifest_version": 3,
  "name": "YouTube Smart Video Search",
  "version": "1.0.0",
  "description": "Semantic search inside YouTube videos — jump to the exact moment.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "content/player.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "offscreen"
  ],

  "host_permissions": [
    "https://www.youtube.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["models/*", "offscreen/*", "content/*"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
